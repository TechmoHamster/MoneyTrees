+function normalizeDebtDuplicateText(value: string | undefined): string {
+  return (value ?? "")
+    .toLowerCase()
+    .replaceAll(/[^a-z0-9]+/g, " ")
+    .trim();
+}
+
+function billLooksLikeDuplicateManualDebtRow(debtBill: Bill, manualBill: Bill): boolean {
+  if (manualBill.sourceType === "debt-derived" || manualBill.category !== "Debt") {
+    return false;
+  }
+
+  const manualAmount = normalizeAmount(getBillTotalAmount(manualBill));
+  const debtAmount = normalizeAmount(getBillTotalAmount(debtBill));
+  if (Math.abs(manualAmount - debtAmount) > 1) {
+    return false;
+  }
+
+  const dueDate = getDateOnly(debtBill.dueDate);
+  const manualDueDate = getDateOnly(manualBill.dueDate);
+  if (!dueDate || !manualDueDate || Math.abs(getDifferenceInDays(dueDate, manualDueDate)) > 7) {
+    return false;
+  }
+
+  const debtName = normalizeDebtDuplicateText(
+    `${debtBill.sourceDebtProviderName ?? ""} ${debtBill.sourceDebtDisplayName ?? debtBill.name}`,
+  );
+  const manualName = normalizeDebtDuplicateText(manualBill.name);
+  if (!debtName || !manualName) {
+    return false;
+  }
+
+  return debtName.includes(manualName) || manualName.includes(debtName);
+}
+
+function buildDuplicateDebtWarningMap(
+  manualBills: Bill[],
+  debtBills: Bill[],
+): Map<string, string[]> {
+  const duplicateMap = new Map<string, string[]>();
+
+  for (const debtBill of debtBills) {
+    const matchingManualIds = manualBills
+      .filter((manualBill) => billLooksLikeDuplicateManualDebtRow(debtBill, manualBill))
+      .map((manualBill) => manualBill.id);
+
+    if (matchingManualIds.length === 0) {
+      continue;
+    }
+
+    duplicateMap.set(debtBill.id, matchingManualIds);
+    for (const manualId of matchingManualIds) {
+      duplicateMap.set(manualId, [...(duplicateMap.get(manualId) ?? []), debtBill.id]);
+    }
+  }
+
+  return duplicateMap;
+}
