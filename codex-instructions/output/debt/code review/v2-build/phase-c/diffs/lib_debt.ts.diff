+  const promoEndDate = account.promoEndDate && isValidDateOnly(account.promoEndDate) ? getDateOnly(account.promoEndDate) : null;
+  const daysUntilPromoEnd = promoEndDate ? getDifferenceInDays(today, promoEndDate) : undefined;
