+
+function getOverlapWarnings(rule: CreditCardCustomMinimumRule): string[] {
+  const warnings: string[] = [];
+  const principal = rule.principalVariable;
+  const baseIncludesWholeStatement =
+    principal === "statement_balance" || principal === "current_balance";
+  const baseAlreadyRollsSubBalances = principal === "balance_subject_to_minimum";
+
+  if (baseIncludesWholeStatement) {
+    if (rule.includeInterestCharged) {
+      warnings.push(
+        `${getValueLabel(principal)} can already reflect interest charges. Adding interest again risks double counting.`,
+      );
+    }
+    if (rule.includeFeesCharged) {
+      warnings.push(
+        `${getValueLabel(principal)} can already reflect fees. Adding fees again risks double counting.`,
+      );
+    }
+    if (rule.includePastDueAmount) {
+      warnings.push(
+        `${getValueLabel(principal)} can already contain past-due carryover. Adding past due again risks overlap.`,
+      );
+    }
+    if (rule.includeLateFeeAmount) {
+      warnings.push(
+        `${getValueLabel(principal)} can already contain late-fee carryover. Adding late fees again risks overlap.`,
+      );
+    }
+    if (rule.includePromoBalance) {
+      warnings.push(
+        `${getValueLabel(principal)} can already include promo balance. Adding promo balance again risks double counting.`,
+      );
+    }
+    if (rule.includeRegularPurchaseBalance) {
+      warnings.push(
+        `${getValueLabel(principal)} can already include regular purchase balance. Adding it again risks double counting.`,
+      );
+    }
+    if (rule.includeCashAdvanceBalance) {
+      warnings.push(
+        `${getValueLabel(principal)} can already include cash advance balance. Adding it again risks double counting.`,
+      );
+    }
+  }
+
+  if (baseAlreadyRollsSubBalances) {
+    if (rule.includePromoBalance) {
+      warnings.push(
+        "Balance subject to minimum already adjusts around promo balance. Adding promo balance again risks overlap.",
+      );
+    }
+    if (rule.includeRegularPurchaseBalance) {
+      warnings.push(
+        "Balance subject to minimum can already include regular purchase balance. Adding it again risks double counting.",
+      );
+    }
+    if (rule.includeCashAdvanceBalance) {
+      warnings.push(
+        "Balance subject to minimum can already include cash advance balance. Adding it again risks double counting.",
+      );
+    }
+  }
+
+  return warnings.filter((warning, index, allWarnings) => allWarnings.indexOf(warning) === index);
